{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2021", "dom"],
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": false,
    "isolatedModules": true,
    "moduleDetection": "force",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "outDir": "./dist",
    "jsx": "react-jsx",
    "esModuleInterop": true
  },
  "include": ["./**/*.ts"]
}
